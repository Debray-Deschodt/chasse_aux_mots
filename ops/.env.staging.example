# .env de l'instance STAGING (à mettre dans /var/www/chasse/staging/.env)
# Volontairement DIFFÉRENT de la prod : autre port, autre domaine, autre base, autre secret.

PORT=8788
BASE_URL=https://staging.chasse-aux-mots.fr

# Secret PROPRE au staging : openssl rand -base64 32
AUTH_SECRET=remplace-moi-staging

# Base de comptes isolée (ne touche pas la prod)
AUTH_DB=file:./auth.db

# Mêmes identifiants Google que la prod possibles, MAIS il faut avoir ajouté dans
# Google Cloud Console l'URI de redirection du staging :
#   https://staging.chasse-aux-mots.fr/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optionnel : manches plus courtes pour tester sans attendre
# PLAY_MS=20000
# BREAK_MS=8000
