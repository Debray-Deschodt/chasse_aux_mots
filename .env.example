# Copie ce fichier en .env et remplis les valeurs

# Origine publique du site (IMPORTANT : exactement le domaine servi)
BASE_URL=https://chasse-aux-mots.fr

# Secret de signature des sessions — génère-le : openssl rand -base64 32
AUTH_SECRET=remplace-moi-par-un-secret-aleatoire

# Base SQLite des comptes (fichier local, persistant)
AUTH_DB=file:./auth.db

# Connexion Google (depuis Google Cloud Console). Laisse vide pour désactiver Google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optionnel : durées des manches (ms)
# PLAY_MS=120000
# BREAK_MS=30000
# PORT=8787
